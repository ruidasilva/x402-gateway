{
  "name": "@merkleworks/x402-client",
  "version": "0.2.0",
  "description": "Client library for the x402-BSV payment protocol. Handles 402 challenges, transaction construction, delegation, broadcast, and proof submission.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "x402",
    "bsv",
    "payment",
    "402",
    "http",
    "micropayments"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
