# x402 Gateway Configuration

# BSV private key (WIF format) for the delegator
# This key controls the fee UTXO pool and nonce pool
BSV_PRIVATE_KEY=

# BSV network: "mainnet" or "testnet"
BSV_NETWORK=testnet

# Service payee address (where payments are sent)
PAYEE_ADDRESS=

# Server port
PORT=8402

# Nonce pool settings
NONCE_POOL_SIZE=100
NONCE_LEASE_TTL=300

# Fee settings
FEE_RATE=1.0

# Broadcaster: "woc" or "arc"
BROADCASTER=woc

# Daily fee budget (satoshis) - 0 for unlimited
DAILY_FEE_BUDGET=0
