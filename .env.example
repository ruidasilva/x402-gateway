# x402 Gateway Configuration
#
# Quick start:  make demo         (auto-generates a key and starts the server)
# Setup wizard: make setup        (interactive CLI wizard)
# Manual setup: go run ./cmd/keygen   (generates .env with a fresh key)

# ─── Key Management ────────────────────────────────────────────
# Choose ONE of XPRIV or BSV_PRIVATE_KEY (xPriv recommended)

# BIP32 extended private key (HD wallet — recommended)
# Derives separate keys for nonce, fee, and treasury pools
# Generate via: go run ./cmd/setup
# XPRIV=xprv9s21ZrQH143K...

# Legacy single-key mode (WIF format)
# Same key used for all pools
BSV_PRIVATE_KEY=

# ─── Network ──────────────────────────────────────────────────
# BSV network: "mainnet" or "testnet"
BSV_NETWORK=testnet

# Broadcaster: "mock" (demo/offline), "woc" (WhatsOnChain only),
#   or "composite" (GorillaPool ARC primary + WoC fallback)
# REQUIRED — no default.
BROADCASTER=mock

# GorillaPool ARC configuration (only used when BROADCASTER=composite)
# ARC_URL=https://arc.gorillapool.io/v1
# ARC_API_KEY=  (optional — GorillaPool doesn't require auth currently)

# ─── Payments ─────────────────────────────────────────────────
# Service payee address (where payments are sent)
# If not set, uses the nonce pool address
PAYEE_ADDRESS=

# Fee rate in sat/byte (BSV standard: 1 sat/KB = 0.001 sat/byte)
# REQUIRED — no default.
FEE_RATE=0.001

# Daily fee budget (satoshis) - 0 for unlimited
DAILY_FEE_BUDGET=0

# ─── Server ──────────────────────────────────────────────────
# HTTP port
PORT=8402

# Nonce pool settings
NONCE_POOL_SIZE=100
NONCE_LEASE_TTL=300

# ─── Storage ─────────────────────────────────────────────────
# Redis (required for production, omit or set to false for demo mode)
# When enabled, UTXO pools are persisted in Redis (survives restarts).
# When disabled, pools are in-memory (reset on restart).
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ─── Fee Pool ────────────────────────────────────────────────
# Fee pool UTXO denomination in satoshis (1–1000, default 100)
# Each fee UTXO should match the payment amount so the delegator
# needs only 1 input per settlement (avoids fee-spiral with many small UTXOs).
FEE_UTXO_SATS=100

# ─── Pool Auto-Refill ────────────────────────────────────────
# Trigger refill when available UTXOs drop below this count
POOL_REPLENISH_THRESHOLD=500
# Target pool size after refill
POOL_OPTIMAL_SIZE=5000
