		{
			"name": "x402 Payment Flow",
			"description": "Core x402 payment protocol flow.\n\n1. Request protected resource → get 402 challenge\n2. Build proof (demo mode) or delegate fee (live mode)\n3. Retry with proof → get 200\n4. Replay same proof → get 409",
			"item": [
				{
					"name": "1. Request Protected Resource (GET → 402)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/expensive",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "expensive"]
						},
						"description": "First request without payment proof. Returns HTTP 402 Payment Required with:\n- X402-Challenge header: base64-encoded JSON challenge\n- X402-Accept header: supported payment schemes\n- Cache-Control: no-store\n\nThe challenge contains: version, scheme, amount_sats (100), payee locking script, expiry, domain/method/path binding, nonce UTXO, and request hashes.\n\nExpected: 402 Payment Required"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 402 Payment Required', () => {",
									"    pm.response.to.have.status(402);",
									"});",
									"",
									"pm.test('Has X402-Challenge header', () => {",
									"    pm.expect(pm.response.headers.has('X402-Challenge')).to.be.true;",
									"    const challenge = pm.response.headers.get('X402-Challenge');",
									"    pm.expect(challenge).to.be.a('string').and.not.empty;",
									"    pm.collectionVariables.set('challengeEncoded', challenge);",
									"});",
									"",
									"pm.test('Has X402-Accept header with bsv-tx-v1', () => {",
									"    pm.expect(pm.response.headers.has('X402-Accept')).to.be.true;",
									"    const accept = pm.response.headers.get('X402-Accept');",
									"    pm.expect(accept).to.include('bsv-tx-v1');",
									"});",
									"",
									"pm.test('Has Cache-Control: no-store', () => {",
									"    const cc = pm.response.headers.get('Cache-Control');",
									"    pm.expect(cc).to.eql('no-store');",
									"});",
									"",
									"pm.test('Response body has payment_required error', () => {",
									"    const body = pm.response.json();",
									"    pm.expect(body.code).to.eql('payment_required');",
									"    pm.expect(body.status).to.eql(402);",
									"});",
									"",
									"pm.test('Challenge decodes to valid JSON', () => {",
									"    const challenge = pm.response.headers.get('X402-Challenge');",
									"    const b64 = challenge.replace(/-/g, '+').replace(/_/g, '/');",
									"    const decoded = JSON.parse(atob(b64));",
									"    pm.expect(decoded.v).to.eql('1');",
									"    pm.expect(decoded.scheme).to.eql('bsv-tx-v1');",
									"    pm.expect(decoded.amount_sats).to.eql(100);",
									"    pm.expect(decoded.nonce_utxo).to.have.property('txid');",
									"    pm.expect(decoded.nonce_utxo).to.have.property('vout');",
									"    pm.expect(decoded.nonce_utxo).to.have.property('satoshis');",
									"    pm.expect(decoded.nonce_utxo).to.have.property('locking_script_hex');",
									"    pm.expect(decoded.payee_locking_script_hex).to.be.a('string');",
									"    pm.expect(decoded.expires_at).to.be.a('number');",
									"    pm.expect(decoded.domain).to.include('localhost');",
									"    pm.expect(decoded.method).to.eql('GET');",
									"    pm.expect(decoded.path).to.eql('/v1/expensive');",
									"    pm.expect(decoded.req_headers_sha256).to.be.a('string');",
									"    pm.expect(decoded.req_body_sha256).to.be.a('string');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "1b. Request Protected Resource (POST → 402)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"example\": \"payload\"}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/expensive",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "expensive"]
						},
						"description": "POST variant of the protected endpoint. Same 402 challenge flow, but the challenge binding includes the request body SHA-256.\n\nExpected: 402 Payment Required"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 402', () => pm.response.to.have.status(402));",
									"",
									"pm.test('Has X402-Challenge header', () => {",
									"    pm.expect(pm.response.headers.has('X402-Challenge')).to.be.true;",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "2. Build Proof (Demo Mode)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"challenge\": \"{{challengeEncoded}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/demo/build-proof",
							"host": ["{{baseUrl}}"],
							"path": ["demo", "build-proof"]
						},
						"description": "Demo-only: builds a complete payment proof server-side.\n\nAccepts the base64-encoded challenge from X402-Challenge header. The server:\n1. Decodes the challenge\n2. Leases a nonce UTXO and payment UTXO\n3. Constructs a partial tx (nonce input + payment input + payee output)\n4. Signs client inputs with SIGHASH_ALL|ANYONECANPAY|FORKID (0xC1)\n5. Delegates to the delegator for fee input addition\n6. Returns a ready-to-use X402-Proof header value\n\nPrerequisite: Run step 1 first to capture challengeEncoded.\n\nExpected: 200 OK"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Proof response is valid', () => {",
									"    const body = pm.response.json();",
									"    pm.expect(body.proof_header).to.be.a('string').and.not.empty;",
									"    pm.expect(body.txid).to.be.a('string').with.lengthOf(64);",
									"    pm.expect(body.challenge_hash).to.be.a('string').with.lengthOf(64);",
									"    pm.collectionVariables.set('proofHeader', body.proof_header);",
									"    console.log('Proof TxID: ' + body.txid);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "3. Access with Proof (GET → 200)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X402-Proof",
								"value": "{{proofHeader}}",
								"description": "Base64-encoded payment proof"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/v1/expensive",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "expensive"]
						},
						"description": "Retry the protected resource with a valid X402-Proof header.\n\nThe gatekeeper validates the proof (version, scheme, binding, mempool acceptance, replay check), then grants access to the protected resource.\n\nPrerequisite: Run step 2 first to capture proofHeader.\n\nExpected: 200 OK"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
									"",
									"pm.test('Received protected data', () => {",
									"    const body = pm.response.json();",
									"    pm.expect(body.data).to.include('100 satoshis');",
									"    pm.expect(body.timestamp).to.be.a('number');",
									"    pm.expect(body.path).to.eql('/v1/expensive');",
									"    console.log('SUCCESS: ' + body.data);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "4. Replay Same Proof (GET → 409)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X402-Proof",
								"value": "{{proofHeader}}",
								"description": "Same proof from step 3 — should be rejected as double-spend"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/v1/expensive",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "expensive"]
						},
						"description": "Replay attack test: resubmit the same proof from step 3.\n\nThe gatekeeper's replay cache detects the nonce UTXO has already been spent and rejects with 409 Conflict (double_spend).\n\nThis proves:\n- Replay cache works correctly\n- Nonce UTXO single-use enforcement\n- RACE-01 fix prevents concurrent bypass\n\nPrerequisite: Step 3 must have succeeded.\n\nExpected: 409 Conflict"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 409 Conflict (double_spend)', () => {",
									"    pm.response.to.have.status(409);",
									"});",
									"",
									"pm.test('Error code is double_spend', () => {",
									"    const body = pm.response.json();",
									"    pm.expect(body.code).to.eql('double_spend');",
									"    pm.expect(body.message).to.be.a('string');",
									"    console.log('Replay correctly rejected: ' + body.message);",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Fee Delegation",
			"description": "Direct fee delegation endpoints.\n\n- POST /delegate/x402 — canonical x402 spec flow (client-constructed partial tx)\n- POST /api/v1/tx — Node.js-compatible fee delegator (JSON tx structure)",
			"item": [
				{
					"name": "Delegate x402 (Spec Flow)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"partial_tx_hex\": \"<hex-encoded-partial-transaction>\",\n    \"challenge_hash\": \"<sha256-of-challenge>\",\n    \"nonce_outpoint\": {\n        \"txid\": \"<nonce-utxo-txid>\",\n        \"vout\": 0\n    },\n    \"payee_locking_script_hex\": \"<payee-locking-script-hex>\",\n    \"amount_sats\": 100\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/delegate/x402",
							"host": ["{{baseUrl}}"],
							"path": ["delegate", "x402"]
						},
						"description": "Canonical x402 fee delegation endpoint.\n\nThe client builds a partial TX with:\n- Input 0: nonce UTXO (signed with 0xC1)\n- Input 1+: payment UTXO(s) (signed with 0xC1)\n- Output 0: payee payment\n\nThe server validates, adds fee inputs, signs those with 0xC1, and returns the completed tx.\n\nRequest fields:\n- partial_tx_hex: hex-encoded partial transaction\n- challenge_hash: SHA-256 of the original challenge\n- nonce_outpoint: {txid, vout} for replay cache\n- payee_locking_script_hex: expected payee (optional, server-side default)\n- amount_sats: minimum payment amount (optional)\n\nResponse on success:\n- txid: computed transaction ID\n- rawtx_hex: completed raw transaction hex\n- accepted: true\n\nExpected with placeholder data: 400 (invalid_proof)"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const status = pm.response.code;",
									"",
									"pm.test('Returns delegation result or error', () => {",
									"    const body = pm.response.json();",
									"    if (status === 200) {",
									"        pm.expect(body.txid).to.be.a('string').with.lengthOf(64);",
									"        pm.expect(body.rawtx_hex).to.be.a('string');",
									"        pm.expect(body.accepted).to.be.true;",
									"    } else {",
									"        pm.expect(body).to.have.property('code');",
									"        pm.expect(body).to.have.property('message');",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Delegate x402 — Missing nonce_outpoint",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"partial_tx_hex\": \"0100000001\",\n    \"challenge_hash\": \"abc123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/delegate/x402",
							"host": ["{{baseUrl}}"],
							"path": ["delegate", "x402"]
						},
						"description": "Negative test: missing nonce_outpoint returns invalid_proof.\n\nExpected: 400"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 400', () => {",
									"    pm.expect(pm.response.code).to.be.within(400, 499);",
									"});",
									"",
									"pm.test('Error code is invalid_proof', () => {",
									"    const body = pm.response.json();",
									"    pm.expect(body.code).to.eql('invalid_proof');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Delegate Fee (Node.js-Compatible)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"txJson\": {\n        \"inputs\": [\n            {\n                \"txid\": \"aabbccdd00112233445566778899aabbccddeeff00112233445566778899aabb\",\n                \"vout\": 0,\n                \"satoshis\": 1000,\n                \"scriptSig\": \"\"\n            }\n        ],\n        \"outputs\": [\n            {\n                \"satoshis\": 100,\n                \"script\": \"76a91489abcdefabbaabbaabbaabbaabbaabbaabbaabba88ac\"\n            }\n        ]\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/tx",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tx"]
						},
						"description": "Node.js-compatible fee delegation endpoint.\n\nAccepts a JSON transaction structure. The server:\n1. Validates inputs/outputs\n2. Calculates miner fee\n3. Leases fee UTXOs\n4. Adds fee inputs and signs with 0xC1\n5. Returns the completed transaction\n\nExpected with placeholder data: 400 or 500"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const status = pm.response.code;",
									"",
									"pm.test('Returns delegation result or error', () => {",
									"    const body = pm.response.json();",
									"    if (status === 200) {",
									"        pm.expect(body.success).to.be.true;",
									"        pm.expect(body.txid).to.be.a('string');",
									"        pm.expect(body.rawtx).to.be.a('string');",
									"        pm.expect(body.fee).to.be.a('number');",
									"        pm.expect(body.mode).to.eql('raw_transaction_returned');",
									"    } else {",
									"        pm.expect(body.success).to.be.false;",
									"        pm.expect(body.error).to.be.a('string');",
									"    }",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Dashboard API",
			"description": "React dashboard backend endpoints for configuration, statistics, and treasury management.",
			"item": [
